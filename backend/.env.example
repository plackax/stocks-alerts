DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=prueba2
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Managed-host path (Render / Railway / Fly): provide a single connection string
# instead of the individual DATABASE_* vars above. When set, it takes precedence.
# DATABASE_URL=postgres://user:pass@host:5432/db
# DATABASE_SSL=true

JWT_SECRET=your-jwt-secret-here
FINNHUB_API_KEY=your-finnhub-api-key-here

# Comma-separated allowlist of CORS origins for REST and the Socket.IO gateway.
# Defaults to localhost dev origins when unset. Set this for any browser client in production.
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
